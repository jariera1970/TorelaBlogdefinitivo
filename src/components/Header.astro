---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="header-banner">
		<img src="/TorelaFoto.jpg" alt="Torela" loading="eager" fetchpriority="high" decoding="async" />
	</div>
	<nav>
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/noticias">Noticias</HeaderLink>
			<HeaderLink href="/tradiciones">Tradiciones</HeaderLink>
			<HeaderLink href="/cultura">Cultura</HeaderLink>
			<HeaderLink href="/deportes">Deportes</HeaderLink>
			<HeaderLink href="/politica">Política</HeaderLink>
			<HeaderLink href="/humor">Humor</HeaderLink>
			<HeaderLink href="/agricultura">Agricultura</HeaderLink>
			<HeaderLink href="/toros">Toros</HeaderLink>
			<HeaderLink href="/hace-30-anos">Hace 30 años</HeaderLink>
			<HeaderLink href="/el-pueblo">El pueblo</HeaderLink>
			<HeaderLink href="/enlaces">Enlaces</HeaderLink>
			<HeaderLink href="/asociacion">Asociacion</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://tortoladehenares.wordpress.com/" target="_blank">
				<span class="sr-only">Ir a la web de Tortola de Henares</span>
				<img
					class="social-icon-img"
					src="/IconoTorela.jpg"
					alt="Icono Torela"
					loading="lazy"
					width="32"
					height="32"
				/>
			</a>
			<a href="https://juanjoseperez.jimdofree.com/" target="_blank">
				<span class="sr-only">Ir a la web de Juan José Pérez</span>
				<img
					class="social-icon-img"
					src="/IconoJoseVideos.jpeg"
					alt="Icono Jose Videos"
					loading="lazy"
					width="32"
					height="32"
				/>
			</a>
			<a href="https://www.facebook.com/asociaciontorela?locale=es_ES" target="_blank">
				<span class="sr-only">Ir al Facebook de Asociacion Torela</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M9.028 15V8.66h2.084l.312-2.47H9.028V4.614c0-.715.192-1.204 1.203-1.204h1.286V1.2C11.294 1.17 10.55 1.1 9.684 1.1c-1.81 0-3.05 1.12-3.05 3.176V6.19H4.58v2.47h2.054V15h2.394Z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		background: white;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}

	nav::before {
		content: '';
		flex: 0 0 112px;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}

	.social-links {
		align-items: center;
		gap: 0.25rem;
		flex: 0 0 112px;
		justify-content: flex-end;
	}

	.social-icon-img {
		width: 32px !important;
		height: 32px !important;
		max-width: 32px;
		max-height: 32px;
		flex: 0 0 32px;
		object-fit: contain;
		display: block;
		border-radius: 4px;
	}

	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}

	.header-banner {
		width: min(1120px, max(320px, calc(100% - 224px - 2em)));
		margin: 0;
		overflow: visible;
		position: relative;
		margin-inline: auto;
	}

	.header-banner img {
		width: 100%;
		height: auto;
		display: block;
		object-fit: contain;
		object-position: center;
	}

	nav {
		position: sticky;
		top: 0;
		z-index: 1000;
	}

	.internal-links {
		display: flex;
		flex: 1 1 auto;
		flex-wrap: nowrap;
		justify-content: center;
		min-width: 0;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.internal-links::-webkit-scrollbar {
		display: none;
	}

	@media (max-width: 900px) {
		.header-banner {
			width: 100%;
		}

		nav {
			gap: 0.5rem;
			align-items: flex-start;
			flex-direction: column;
		}

		nav::before {
			display: none;
		}

		.internal-links {
			flex-wrap: wrap;
			overflow-x: visible;
			row-gap: 0.25rem;
		}
	}
</style>
