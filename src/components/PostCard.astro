---
import FormattedDate from './FormattedDate.astro';
import { toAbsoluteStrapiUrl } from '../lib/strapi';

const { post } = Astro.props;

function imageUrl(media: any): string | null {
  if (!media) return null;

  if (typeof media === 'string') {
    const trimmed = media.trim();
    if (!trimmed) return null;
    return toAbsoluteStrapiUrl(trimmed);
  }

  if (Array.isArray(media)) {
    for (const item of media) {
      const url: string | null = imageUrl(item);
      if (url) return url;
    }
    return null;
  }

  if (Array.isArray(media?.data)) {
    return imageUrl(media.data);
  }

  if (media?.data) {
    return imageUrl(media.data);
  }

  if (media?.attributes) {
    return imageUrl(media.attributes);
  }

  if (typeof media?.url === 'string') {
    const trimmed = media.url.trim();
    if (!trimmed) return null;
    return toAbsoluteStrapiUrl(trimmed);
  }

  return null;
}

function slugFromTitle(title: string) {
  return title
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-');
}

function uniquePostSlug(post: any): string {
  const base = slugFromTitle(typeof post?.Titulo === 'string' ? post.Titulo : 'post');
  const uniqueId =
    typeof post?.UID === 'string' && post.UID.trim()
      ? post.UID.trim()
      : typeof post?.documentId === 'string' && post.documentId.trim()
      ? post.documentId.trim()
      : String(post?.id || '');

  return uniqueId ? `${base}-${uniqueId.toLowerCase()}` : base;
}

function getPostExcerpt(encabezado: any): string {
  if (!encabezado) return '';

  if (typeof encabezado === 'string') {
    return encabezado.trim();
  }

  if (!Array.isArray(encabezado)) {
    return '';
  }

  const text = encabezado
    .flatMap((block: any) => {
      if (typeof block?.children === 'string') {
        return [block.children];
      }
      if (Array.isArray(block?.children)) {
        return block.children
          .map((child: any) => (typeof child?.text === 'string' ? child.text : ''))
          .filter(Boolean);
      }
      return [];
    })
    .join(' ')
    .replace(/\s+/g, ' ')
    .trim();

  return text;
}

function isVideoMedia(media: any): boolean {
  if (!media) return false;

  if (Array.isArray(media)) {
    return media.some((item) => isVideoMedia(item));
  }

  if (Array.isArray(media?.data)) {
    return isVideoMedia(media.data);
  }

  if (media?.data) {
    return isVideoMedia(media.data);
  }

  if (media?.attributes) {
    return isVideoMedia(media.attributes);
  }

  const mime = media?.mime;
  if (mime) return (mime as string).startsWith('video/');

  const url = media?.url || (typeof media === 'string' ? media : null);
  return url ? /\.(mp4|webm|ogg|mov|avi|mkv)(\?.*)?$/i.test(url) : false;
}

const title = typeof post?.Titulo === 'string' ? post.Titulo.trim() : '';
const slug = title ? uniquePostSlug(post) : '';
const coverUrl = imageUrl(post?.Portada || post?.cover || post?.image);
const rawMedia1 = post?.Media1 || post?.blocks?.[0]?.Media1;
const media1Url = !isVideoMedia(rawMedia1) ? imageUrl(rawMedia1) : null;
const image = coverUrl || media1Url;
const excerpt = getPostExcerpt(post?.Encabezado);
const publishedDate = post?.Publicado ? new Date(post.Publicado) : null;
const hasValidDate = publishedDate && !Number.isNaN(publishedDate.valueOf());
---

{title && slug && (
  <li class="post-card">
    <a class="post-card-link" href={`/blog/${slug}/`}>
      {image && <img class="post-thumb" src={image} alt={title} loading="lazy" />}
      <div class="post-content">
        <h3 class="post-title">{title}</h3>
        {excerpt && <p class="post-excerpt">{excerpt}</p>}
        {hasValidDate && (
          <p class="post-date">
            <FormattedDate date={publishedDate as Date} />
          </p>
        )}
      </div>
    </a>
  </li>
)}
