---
import { getPosts, sortPosts } from '../../lib/strapi';
import TopMenu from '../../components/TopMenu.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

export const prerender = false;

const allPosts = sortPosts(await getPosts());
const categories = Array.from(new Set(allPosts.map((post) => post.Categoria || 'Sin categoría')))
	.map((name) => ({
		name,
		slug: name.toLowerCase().replace(/\s+/g, '-'),
	}));

const categorySlug = Astro.params.slug;
const categoryName = categories.find((c) => c.slug === categorySlug)?.name || 'Sin categoría';

const posts = allPosts.filter((post) => {
	const postCat = (post.Categoria || 'Sin categoría').toLowerCase().replace(/\s+/g, '-');
	return postCat === categorySlug;
});
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{categoryName} - Torela</title>
	</head>
	<body>
		<Header />
		<TopMenu categories={categories} active={categorySlug} />
		<main>
			<section>
				<h1>{categoryName}</h1>
				{posts.length === 0 ? (
					<p>No hay artículos en esta categoría aún.</p>
				) : (
					<ul>
						{posts.map((post) => (
							<li key={post.id} style="margin-bottom:1rem;">
								<h3>{post.Titulo}</h3>
								<time>{new Date(post.Publicado).toLocaleDateString('es-ES')}</time>
								<p>{post.Encabezado?.[0]?.children?.[0]?.text || ''}</p>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
