---
import { getPosts, sortPosts } from '../../lib/strapi';
import TopMenu from '../../components/TopMenu.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
	const allPosts = sortPosts(await getPosts());
	const categories = (Array.from(new Set(allPosts.map((post: any) => post.Categoria || 'Sin categoria'))) as string[])
		.map((name) => ({
			name,
			slug: name.toLowerCase().replace(/\s+/g, '-'),
		}));

	return categories.map((category: { name: string; slug: string }) => {
		const posts = allPosts.filter((post: any) => {
			const postCat = (post.Categoria || 'Sin categoria').toLowerCase().replace(/\s+/g, '-');
			return postCat === category.slug;
		});

		return {
			params: { slug: category.slug },
			props: {
				categories,
				categorySlug: category.slug,
				categoryName: category.name,
				posts,
			},
		};
	});
}

const allPosts = sortPosts(await getPosts());
const categories = (Array.from(new Set(allPosts.map((post: any) => post.Categoria || 'Sin categoría'))) as string[])
	.map((name) => ({
		name,
		slug: name.toLowerCase().replace(/\s+/g, '-'),
	}));

const { categories: categoriesFromProps, categorySlug, categoryName, posts } = Astro.props as {
	categories?: Array<{ name: string; slug: string }>;
	categorySlug?: string;
	categoryName?: string;
	posts?: any[];
};
const categoriesToRender = categoriesFromProps || categories;
const postsToRender = posts || [];
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{categoryName} - Torela</title>
	</head>
	<body>
		<Header />
		<TopMenu categories={categoriesToRender} active={categorySlug} />
		<main>
			<section>
				<h1>{categoryName}</h1>
				{postsToRender.length === 0 ? (
					<p>No hay artículos en esta categoría aún.</p>
				) : (
					<ul>
						{postsToRender.map((post) => (
							<li style="margin-bottom:1rem;">
								<h3>{post.Titulo}</h3>
								<time>{new Date(post.Publicado).toLocaleDateString('es-ES')}</time>
								<p>{post.Encabezado?.[0]?.children?.[0]?.text || ''}</p>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
