---
import { getPosts } from '../../lib/strapi';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export const prerender = false;

const allPosts = await getPosts();
const posts = allPosts.filter((post) => post.Categoria === 'Política' && post.Titulo);

function imageUrl(media) {
if (!media) return null;
if (typeof media === 'string') {
const trimmed = media.trim();
if (!trimmed) return null;
if (trimmed.startsWith('http://') || trimmed.startsWith('https://')) return trimmed;
return `http://localhost:1337${trimmed.startsWith('/') ? '' : '/'}${trimmed}`;
}
if (media?.data?.attributes?.url) {
const url = media.data.attributes.url;
return url.startsWith('http') ? url : `http://localhost:1337${url}`;
}
if (media?.attributes?.url) {
const url = media.attributes.url;
return url.startsWith('http') ? url : `http://localhost:1337${url}`;
}
if (media?.url) {
const url = media.url;
return url.startsWith('http') ? url : `http://localhost:1337${url}`;
}
return null;
}
---

<!doctype html>
<html lang="en">
<head>
<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
<Header />
<main>
<section>
<ul>
{posts.map((post) => {
const coverUrl = imageUrl(post.Portada || post.cover || post.image);
const media1Url = imageUrl(post.Media1 || post.blocks?.[0]?.Media1);
const image = coverUrl || media1Url;
return (
<li>
<a href={`/blog/${post.Titulo.toLowerCase().replace(/\s+/g, '-')}/`}>
{image && <img src={image} alt={post.Titulo} />}
<h4 class="title">{post.Titulo}</h4>
<p class="date"><FormattedDate date={new Date(post.Publicado)} /></p>
</a>
</li>
);
})}
</ul>
</section>
</main>
<Footer />
</body>
</html>
