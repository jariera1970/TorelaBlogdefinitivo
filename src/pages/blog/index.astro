---
import { getPosts, toAbsoluteStrapiUrl } from '../../lib/strapi';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export const prerender = false;

const posts = await getPosts();

function slugFromTitle(title: string) {
return title
.toLowerCase()
.normalize('NFD')
.replace(/[\u0300-\u036f]/g, '')
.replace(/[^a-z0-9\s-]/g, '')
.trim()
.replace(/\s+/g, '-');
}

function uniquePostSlug(post: any): string {
const base = slugFromTitle(typeof post?.Titulo === 'string' ? post.Titulo : 'post');
const uniqueId =
typeof post?.UID === 'string' && post.UID.trim()
? post.UID.trim()
: typeof post?.documentId === 'string' && post.documentId.trim()
? post.documentId.trim()
: String(post?.id || '');

return uniqueId ? `${base}-${uniqueId.toLowerCase()}` : base;
}

function imageUrl(media: any) {
if (!media) return null;
if (typeof media === 'string') {
const trimmed = media.trim();
if (!trimmed) return null;
return toAbsoluteStrapiUrl(trimmed);
}
if (media?.data?.attributes?.url) {
const url = media.data.attributes.url;
return toAbsoluteStrapiUrl(url);
}
if (media?.attributes?.url) {
const url = media.attributes.url;
return toAbsoluteStrapiUrl(url);
}
if (media?.url) {
const url = media.url;
return toAbsoluteStrapiUrl(url);
}
return null;
}
---

<!doctype html>
<html lang="en">
<head>
<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
<Header />
<main>
<section>
<ul>
{posts.map((post: any) => {
const coverUrl = imageUrl(post.Portada || post.cover || post.image);
const media1Url = imageUrl(post.Media1 || post.blocks?.[0]?.Media1);
const image = coverUrl || media1Url;
return (
<li>
<a href={`/blog/${uniquePostSlug(post)}/`}>
{image && <img src={image} alt={post.Titulo} />}
<h4 class="title">{post.Titulo}</h4>
<p class="date"><FormattedDate date={new Date(post.Publicado)} /></p>
</a>
</li>
);
})}
</ul>
</section>
</main>
<Footer />
</body>
</html>
