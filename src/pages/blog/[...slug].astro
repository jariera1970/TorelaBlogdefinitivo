---
import { getPosts } from '../../lib/strapi';
import BaseHead from '../../components/BaseHead.astro';

export const prerender = false;
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

function slugFromTitle(title: string) {
	return title
		.toLowerCase()
		.normalize('NFD')
		.replace(/[\u0300-\u036f]/g, '')
		.replace(/[^a-z0-9\s-]/g, '')
		.trim()
		.replace(/\s+/g, '-');
}

export async function getStaticPaths() {
	const posts = await getPosts();
	return posts.map((post: any) => ({
		params: { slug: slugFromTitle(post.Titulo) }
	}));
}

const STRAPI_URL = 'http://localhost:1337';

function getStrapiImageUrl(media: any) {
	if (!media) return null;
	if (typeof media === 'string') {
		const trimmed = media.trim();
		if (!trimmed) return null;
		return trimmed.startsWith('http://') || trimmed.startsWith('https://')
			? trimmed
			: `${STRAPI_URL}${trimmed.startsWith('/') ? '' : '/'}${trimmed}`;
	}
	if (media?.data?.attributes?.url) {
		const url = media.data.attributes.url;
		return url.startsWith('http') ? url : `${STRAPI_URL}${url}`;
	}
	if (media?.attributes?.url) {
		const url = media.attributes.url;
		return url.startsWith('http') ? url : `${STRAPI_URL}${url}`;
	}
	if (media?.url) {
		const url = media.url;
		return url.startsWith('http') ? url : `${STRAPI_URL}${url}`;
	}
	return null;
}

const slug = (Astro.params as { slug?: string }).slug;
const posts = await getPosts();
const post = posts.find((p: any) => slugFromTitle(p.Titulo) === slug);

if (!post) {
	throw new Error(`Post no encontrado: ${slug}`);
}

const title = post.Titulo;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={post.Categoria} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<h1>{post.Titulo}</h1>
				<p class="meta">
					<span class="category">{post.Categoria}</span>
					<span class="date">{new Date(post.Publicado).toLocaleDateString('es-ES')}</span>
				</p>
				
				{post.Encabezado?.[0]?.children?.[0]?.text && (
					<div class="intro">
						{post.Encabezado[0].children[0].text}
					</div>
				)}

				{post.blocks?.map((block: any) => {
					const media1Url = getStrapiImageUrl(block.Media1);
					const media2Url = getStrapiImageUrl(block.Media2);
					return (
						<section class="block">
							{block.Cuerpo1 && (
								<p>{block.Cuerpo1}</p>
							)}
							
							{media1Url && (
								<img src={media1Url} alt={title} />
							)}
							
							{block.Cuerpo2 && (
								<p>{block.Cuerpo2}</p>
							)}
							
							{media2Url && (
								<img src={media2Url} alt={title} />
							)}
						</section>
					);
				})}
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 2rem;
	}
	article {
		line-height: 1.8;
	}
	h1 {
		font-size: 2.5rem;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}
	.meta {
		display: flex;
		gap: 1rem;
		margin-bottom: 2rem;
		color: #666;
		font-size: 0.95rem;
	}
	.category {
		background-color: #f0f0f0;
		padding: 0.25rem 0.75rem;
		border-radius: 20px;
		font-weight: 500;
	}
	.intro {
		font-size: 1.2rem;
		font-weight: 500;
		margin-bottom: 2rem;
		padding: 1.5rem;
		background-color: #f9f9f9;
		border-left: 4px solid #007bff;
	}
	.block {
		margin-bottom: 2rem;
	}
	.block p {
		margin-bottom: 1rem;
		color: #333;
	}
	img {
		max-width: 100%;
		height: auto;
		margin: 2rem 0;
		border-radius: 8px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
	}
</style>
