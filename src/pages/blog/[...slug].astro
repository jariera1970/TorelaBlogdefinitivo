---
import { getPosts, toAbsoluteStrapiUrl } from '../../lib/strapi';
import BaseHead from '../../components/BaseHead.astro';

import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

function slugFromTitle(title: string) {
	return title
		.toLowerCase()
		.normalize('NFD')
		.replace(/[\u0300-\u036f]/g, '')
		.replace(/[^a-z0-9\s-]/g, '')
		.trim()
		.replace(/\s+/g, '-');
}

function uniquePostSlug(post: any) {
	const base = slugFromTitle(post?.Titulo || 'post');
	const uniqueId =
		typeof post?.UID === 'string' && post.UID.trim()
			? post.UID.trim()
			: typeof post?.documentId === 'string' && post.documentId.trim()
				? post.documentId.trim()
				: String(post?.id || '');

	return uniqueId ? `${base}-${uniqueId.toLowerCase()}` : base;
}

export async function getStaticPaths() {
	const posts = await getPosts();
	return posts.map((post: any) => ({
		params: {
			slug: (() => {
				const base = String(post?.Titulo || 'post')
					.toLowerCase()
					.normalize('NFD')
					.replace(/[\u0300-\u036f]/g, '')
					.replace(/[^a-z0-9\s-]/g, '')
					.trim()
					.replace(/\s+/g, '-');
				const uniqueId =
					typeof post?.UID === 'string' && post.UID.trim()
						? post.UID.trim()
						: typeof post?.documentId === 'string' && post.documentId.trim()
							? post.documentId.trim()
							: String(post?.id || '');
				return uniqueId ? `${base}-${uniqueId.toLowerCase()}` : base;
			})(),
		}
	}));
}

function resolveAbsoluteUrl(rawUrl: string): string {
	return toAbsoluteStrapiUrl(rawUrl);
}

function extractMediaAsset(media: any): { rawUrl: string | null; mime: string | null } {
	if (!media) return { rawUrl: null, mime: null };

	if (typeof media === 'string') {
		const raw = media.trim();
		return { rawUrl: raw || null, mime: null };
	}

	if (Array.isArray(media)) {
		for (const item of media) {
			const result = extractMediaAsset(item);
			if (result.rawUrl) return result;
		}
		return { rawUrl: null, mime: null };
	}

	if (Array.isArray(media?.data)) {
		return extractMediaAsset(media.data);
	}

	if (media?.data) {
		return extractMediaAsset(media.data);
	}

	if (media?.attributes) {
		return extractMediaAsset(media.attributes);
	}

	if (typeof media?.url === 'string' && media.url.trim()) {
		return {
			rawUrl: media.url.trim(),
			mime: typeof media?.mime === 'string' ? media.mime : null
		};
	}

	if (typeof media?.src === 'string' && media.src.trim()) {
		return {
			rawUrl: media.src.trim(),
			mime: typeof media?.mime === 'string' ? media.mime : null
		};
	}

	return { rawUrl: null, mime: typeof media?.mime === 'string' ? media.mime : null };
}

function getStrapiMediaInfo(media: any): { url: string | null; isVideo: boolean; isEmbed: boolean } {
	const { rawUrl, mime } = extractMediaAsset(media);
	if (!rawUrl) return { url: null, isVideo: false, isEmbed: false };

	const url = resolveAbsoluteUrl(rawUrl);

	if (/odysee\.com\//i.test(url)) {
		const embedUrl = url.includes('/$/embed/') ? url : url.replace('odysee.com/', 'odysee.com/$/embed/');
		return { url: embedUrl, isVideo: true, isEmbed: true };
	}

	const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?/]+)/i);
	if (ytMatch) {
		return { url: `https://www.youtube.com/embed/${ytMatch[1]}`, isVideo: true, isEmbed: true };
	}
	if (/youtube\.com\/embed\//i.test(url)) {
		return { url, isVideo: true, isEmbed: true };
	}

	const vimeoMatch = url.match(/vimeo\.com\/(\d+)/i);
	if (vimeoMatch) {
		return { url: `https://player.vimeo.com/video/${vimeoMatch[1]}`, isVideo: true, isEmbed: true };
	}

	const isVideoByMime = typeof mime === 'string' ? mime.startsWith('video/') : false;
	const isVideoByExt = /\.(mp4|webm|ogg|mov|avi|mkv)(\?.*)?$/i.test(url);

	return { url, isVideo: isVideoByMime || isVideoByExt, isEmbed: false };
}

const slug = (Astro.params as { slug?: string }).slug;
const posts = await getPosts();
const post = posts.find((p: any) => uniquePostSlug(p) === slug)
	|| posts.find((p: any) => slugFromTitle(p.Titulo) === slug);

if (!post) {
	throw new Error(`Post no encontrado: ${slug}`);
}

const title = post.Titulo;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={post.Categoria} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<h1>{post.Titulo}</h1>
				<p class="meta">
					<span class="category">{post.Categoria}</span>
					<span class="date">{new Date(post.Publicado).toLocaleDateString('es-ES')}</span>
				</p>
				
				{post.Encabezado?.[0]?.children?.[0]?.text && (
					<div class="intro">
						{post.Encabezado[0].children[0].text}
					</div>
				)}

				{post.blocks?.map((block: any) => {
					const media1 = getStrapiMediaInfo(block.Media1);
					const media2 = getStrapiMediaInfo(block.Media2);
					return (
						<section class="block">
							{block.Cuerpo1 && (
								<p>{block.Cuerpo1}</p>
							)}

							{media1.url && (
								media1.isEmbed
									? <iframe src={media1.url} class="block-media-embed" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" />
									: media1.isVideo
									? <video src={media1.url} controls class="block-media" />
									: <img src={media1.url} alt={title} class="block-media" />
							)}

							{block.Cuerpo2 && (
								<p>{block.Cuerpo2}</p>
							)}

							{media2.url && (
								media2.isEmbed
									? <iframe src={media2.url} class="block-media-embed" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" />
									: media2.isVideo
									? <video src={media2.url} controls class="block-media" />
									: <img src={media2.url} alt={title} class="block-media" />
							)}
						</section>
					);
				})}
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 960px;
		margin: 0 auto;
		padding: 2rem;
	}
	article {
		line-height: 1.8;
	}
	h1 {
		font-size: 2.5rem;
		margin-bottom: 1rem;
		color: #1a1a1a;
	}
	.meta {
		display: flex;
		gap: 1rem;
		margin-bottom: 2rem;
		color: #666;
		font-size: 0.95rem;
	}
	.category {
		background-color: #f0f0f0;
		padding: 0.25rem 0.75rem;
		border-radius: 20px;
		font-weight: 500;
	}
	.intro {
		font-size: 1.2rem;
		font-weight: 500;
		margin-bottom: 2rem;
		padding: 1.5rem;
		background-color: #f9f9f9;
		border-left: 4px solid #007bff;
	}
	.block {
		margin-bottom: 2rem;
	}
	.block p {
		margin-bottom: 1rem;
		color: #333;
	}
	.block-media {
		max-width: 100%;
		height: auto;
		margin: 2rem 0;
		border-radius: 8px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		display: block;
	}
	.block-media-embed {
		width: 100%;
		aspect-ratio: 16 / 9;
		margin: 2rem 0;
		border-radius: 8px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		border: none;
		display: block;
	}
</style>
