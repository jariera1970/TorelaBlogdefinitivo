---
import { getPosts, sortPosts } from '../lib/strapi';
import TopMenu from '../components/TopMenu.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

export const prerender = false;

const rawPosts = await getPosts();
const posts = sortPosts(rawPosts);
const newest = posts.slice(0, 10);
const categories = Array.from(new Set(posts.map((post) => post.Categoria || 'Sin categoría')))
	.map((name) => ({
		name,
		slug: name.toLowerCase().replace(/\s+/g, '-'),
	}));
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Torela - Inicio</title>
	</head>
	<body>
		<Header />
		<TopMenu categories={categories} active="home" />
		<main>
			<section>
				<h1>Inicio</h1>
				<p>Los artículos más recientes (máx. 10 en Inicio):</p>
				<ul>
					{newest.map((post) => (
						<li key={post.id} style="margin-bottom: 1.2rem;">
							<a href={`/category/${(post.Categoria || 'sin-categoria').toLowerCase().replace(/\s+/g, '-')}/`}>
								<span style="font-size:0.9rem;color:#666;">{post.Categoria || 'Sin categoría'}</span>
							</a>
							<h3>{post.Titulo}</h3>
							<time style="color:#666;">{new Date(post.Publicado).toLocaleDateString('es-ES')}</time>
							<p>{post.Encabezado?.[0]?.children?.[0]?.text || ''}</p>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
